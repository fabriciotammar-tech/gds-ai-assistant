import ipywidgets as widgets
from IPython.display import display, Markdown

# 1. Definición del Cerebro del Asistente (Multiproblemática)
# Aquí aplicamos Fast Prompting: un solo bloque de instrucciones que cubre todo
def obtener_instrucciones_sistema(categoria):
    logicas = {
        'um_policy': "Experto en Menores Solos (UMNR). Prioriza SSR UMNR, políticas Kids Solo y datos de contacto de adultos[cite: 16, 61].",
        'reissue_policy': "Experto en Reemisiones. Prioriza comandos de cotización (FXP, FXQ) y manejo de tickets abiertos[cite: 53, 71].",
        'ancillaries_policy': "Experto en Servicios Auxiliares. Prioriza emisión de EMD-S para asientos, equipaje y servicios especiales[cite: 70].",
        'incidencia_docs': "Experto en Documentación. Prioriza pasos legales, SR DOCS y autorizaciones de emergencia[cite: 35, 76]."
    }
    contexto = logicas.get(categoria, "Experto en operativa GDS general.")
    
    return f"""
    Eres un Asistente Senior de Operaciones Turísticas. {contexto}
    Tu función es recibir datos de una contingencia y devolver:
    1. Políticas de la aerolínea.
    2. Comandos exactos para el GDS solicitado (Amadeus/Sabre).
    3. Pasos legales o migratorios.
    Sé conciso y técnico.
    """

# 2. Interfaz Interactiva Mejorada (Valor Agregado)
categoria_dropdown = widgets.Dropdown(
    options=[
        ('Menores No Acompañados (UMNR)', 'um_policy'),
        ('Cambio de Fecha / Reemisión', 'reissue_policy'),
        ('Compra de Servicios (Asientos)', 'ancillaries_policy'),
        ('Robo/Falta de Documentos', 'incidencia_docs')
    ],
    description='Trámite:',
)

aerolinea_input = widgets.Text(description="Aerolínea:", placeholder="Ej: Air France")
gds_input = widgets.Dropdown(options=['Amadeus', 'Sabre', 'Galileo'], description="GDS:")
pasajero_input = widgets.Text(description="Pasajero:", placeholder="Ej: Menor de 10 años")
detalle_input = widgets.Textarea(description="Incidente:", placeholder="Ej: Pasajero perdió su vuelo por robo de permiso [cite: 4]")
boton_generar = widgets.Button(description="Generar Solución", button_style='success', icon='plane')
output = widgets.Output()

# 3. Función de Procesamiento Unificada
def procesar_solucion(b):
    with output:
        output.clear_output()
        # Fast Prompting: Optimizamos la consulta enviando la lógica y los datos en un solo paso
        print(f"⚙️ Optimizando consulta integral para {aerolinea_input.value} en {gds_input.value}...")

        # El prompt final que viajaría a la API de IA
        prompt_de_sistema = obtener_instrucciones_sistema(categoria_dropdown.value)
        
        # Simulación de respuesta estructurada (Motor Técnico)
        # Aquí se mantiene la base de tu Preentrega 1 pero se hace dinámica
        respuesta = f"""
### 🛠 Hoja de Ruta Operativa: {aerolinea_input.value}
---
#### 1. Política y Protocolo
* Se aplica el protocolo para **{pasajero_input.value}**[cite: 19].
* Verificar disponibilidad de cupo en la aerolínea antes de proceder[cite: 30].

#### 2. Procedimiento Técnico en {gds_input.value}
* **Comandos Principales:** Dependiendo del trámite, usar SSR específicos (ej: UMNR)[cite: 57, 59].
* **Gestión de Cargos:** El cobro se realiza mediante **EMD-S** (Electronic Miscellaneous Document)[cite: 70].
* **Cierre de Reserva:** Obligatorio actualizar campos de contacto (PCTC) y cerrar con RF/ER[cite: 80, 84].

#### 3. Pasos Legales y de Emergencia
* En caso de incidencias con permisos [cite: 4], gestionar autorización ante Escribano[cite: 38].
* **Opción Urgente:** Recordar la oficina de Migraciones en el Aeropuerto para autorizaciones al instante[cite: 42].
        """
        display(Markdown(respuesta))

boton_generar.on_click(procesar_solucion)

# Mostrar la herramienta
display(Markdown("### ✈️ GDS AI-Assistant: Consola de Operaciones Integral"))
display(categoria_dropdown, aerolinea_input, gds_input, pasajero_input, detalle_input, boton_generar, output)
